# Play log credentials. Copy to `.env` in the project root on the device
# (`.env` is gitignored and not synced by `make deploy`). Real environment
# variables take precedence over this file. If either var is unset, the
# play log is silently disabled.

# Supabase project REST URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# API key for the play_log table. Use the publishable key (sb_publishable_...,
# formerly the anon key) paired with the insert+select RLS policy in
# supabase_schema.sql — never a secret/service_role key — so a leaked key
# can add noise at worst, never update or delete history.
# SUPABASE_PUBLISHABLE_KEY is accepted as an alias.
SUPABASE_KEY=

# Personal access token (supabase.com -> Account -> Access Tokens, sbp_...).
# Only used by `make setup_supabase` to apply the schema via the Management
# API — NOT needed on the device. It is account-wide, so keep it in your
# dev-machine .env (never deployed; `make deploy` skips dotfiles), never on
# the RPi.
SUPABASE_ACCESS_TOKEN=
